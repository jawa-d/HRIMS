rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userRole() {
      return isSignedIn() && exists(userDocPath()) ? get(userDocPath()).data.role : "";
    }

    function hasRole(roles) {
      return isSignedIn() && userRole() in roles;
    }

    function isAdmin() {
      return hasRole(["super_admin", "hr_admin"]);
    }

    function isManagerOrAbove() {
      return hasRole(["super_admin", "hr_admin", "manager"]);
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function immutableFieldsUnchanged(fields) {
      return request.resource.data.diff(resource.data).changedKeys().hasAny(fields) == false;
    }

    match /users/{uid} {
      // Direct email-login mode relies on querying users by email from the client.
      allow read: if isSignedIn() || isOwner(uid) || isManagerOrAbove();
      allow create: if isAdmin() && request.resource.data.uid == uid;
      allow update: if isAdmin() || (isOwner(uid) && immutableFieldsUnchanged(["role", "status", "permissions"]));
      allow delete: if isAdmin();
    }

    match /employees/{id} {
      allow read: if isManagerOrAbove() || isSignedIn();
      // Direct email-login mode may not map role to Firebase UID consistently.
      // Allow signed-in Firebase sessions to persist employee changes.
      allow create, update, delete: if isManagerOrAbove() || isSignedIn();
    }

    match /departments/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    match /positions/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    match /leaves/{id} {
      allow read: if isManagerOrAbove() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isManagerOrAbove() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow delete: if isManagerOrAbove() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
    }

    match /attendance/{id} {
      allow read: if isManagerOrAbove() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow write: if isManagerOrAbove();
    }

    match /payroll/{id} {
      // Payroll page currently runs in direct email-login mode. This mode does not always
      // map Firebase auth UID to /users/{uid}, so role-based checks can block valid saves.
      // Keep role checks, but allow authenticated Firebase sessions to read/write payroll.
      allow read: if isManagerOrAbove()
        || (isSignedIn() && resource.data.employeeId == request.auth.uid)
        || isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }

    match /assets/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    match /timeoff_balances/{id} {
      allow read: if isManagerOrAbove() || isOwner(id);
      allow write: if isManagerOrAbove();
    }

    match /tickets/{id} {
      allow read: if isManagerOrAbove() || (isSignedIn() && resource.data.requesterUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.requesterUid == request.auth.uid;
      allow update, delete: if isManagerOrAbove() || (isSignedIn() && resource.data.requesterUid == request.auth.uid);
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow create: if isManagerOrAbove();
      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    match /secure_vault_entries/{id} {
      allow read, write: if isAdmin();
    }

    match /security_audit/{id} {
      allow read: if isManagerOrAbove();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /accounting_entries/{id} {
      allow read: if isManagerOrAbove();
      allow write: if hasRole(["super_admin", "hr_admin"]);
    }

    match /accounting_chart_accounts/{id} {
      allow read: if isManagerOrAbove();
      allow write: if hasRole(["super_admin", "hr_admin"]);
    }

    match /accounting_obligations/{id} {
      allow read: if isManagerOrAbove();
      allow write: if hasRole(["super_admin", "hr_admin"]);
    }

    match /accounting_obligation_movements/{id} {
      allow read: if isManagerOrAbove();
      allow write: if hasRole(["super_admin", "hr_admin"]);
    }

    match /barcode_exports/{id} {
      allow read: if isManagerOrAbove();
      allow write: if isManagerOrAbove();
    }

    match /insurance_documents/{id} {
      // Insurance docs page currently runs with direct/anonymous Firebase sessions in some flows.
      // Keep role-based access, but allow authenticated sessions similar to payroll behavior.
      allow read: if isManagerOrAbove() || isSignedIn();
      allow write: if isManagerOrAbove() || isSignedIn();
    }

    match /insurance_parties/{id} {
      allow read: if isManagerOrAbove() || isSignedIn();
      allow write: if isManagerOrAbove() || isSignedIn();
    }

    match /barcode_inline_files/{id} {
      allow read: if isSignedIn() || (resource.data.isPublic == true);
      allow write: if isManagerOrAbove();
    }

    match /barcode_inline_file_chunks/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    match /excel_sheet_inputs/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    match /system_backups/{id} {
      allow read, write: if isAdmin();
    }

    match /app_config/{id} {
      allow read: if isManagerOrAbove() || (isSignedIn() && id == "settings_rbac");
      allow write: if isAdmin();
    }

    match /app_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
